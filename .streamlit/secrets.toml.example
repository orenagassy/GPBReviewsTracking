# Copy this file to secrets.toml and fill in your values.
# secrets.toml is gitignored and must never be committed.

[google]
client_id = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"
# For local dev: http://localhost:8501
# For Streamlit Community Cloud: https://your-app-name.streamlit.app
redirect_uri = "http://localhost:8501"
